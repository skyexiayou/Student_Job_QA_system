# Optional: if left blank, the system scans the sibling API Key folder.
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-plus
LLM_TIMEOUT=60
ALLOW_LLM_FALLBACK=true

# Retrieval and chunking
DEFAULT_TOP_K=4
SIMILARITY_THRESHOLD=0
GRAPH_HOPS=2
CHUNK_SIZE=650
CHUNK_OVERLAP=100
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
USE_HF_EMBEDDING=true
HF_LOCAL_FILES_ONLY=true
MAX_UPLOAD_SIZE_MB=30

# Neo4j GraphRAG. Leave blank to use local vector fallback only.
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_INDEX=job_chunk_embedding_index
NEO4J_VECTOR_DIMENSION=384

# User management and conversation data
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_job_qa

# Runtime
LOG_LEVEL=INFO
