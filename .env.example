# 可选：如果不填写，系统会自动扫描：
# E:\26大三下\26课内学习\生产实习\API Key\*.csv
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=qwen-plus

# 可选配置
DEFAULT_TOP_K=4
MEMORY_ROUNDS=4
ALLOW_LLM_FALLBACK=true
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
USE_HF_EMBEDDING=true
HF_LOCAL_FILES_ONLY=true

# 用户系统数据库：默认 sqlite；需要 MySQL 时改成 mysql 并填写连接信息
DB_BACKEND=sqlite
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rag_job_qa
